# Vitrail — variables d'environnement requises
# Copier en .env et renseigner avant le premier lancement.

# Niveau de log global (trace|debug|info|warn|error)
VITRAIL_LOG_LEVEL=info

# Emplacement de la base SQLite (par défaut: $XDG_DATA_HOME/vitrail/vitrail.db)
VITRAIL_DB_PATH=

# Emplacement du fichier SSLKEYLOGFILE géré par Vitrail
VITRAIL_KEYLOG_PATH=

# Nom de la chaîne nftables dédiée (ne pas modifier sauf collision connue)
VITRAIL_NFT_CHAIN=VITRAIL_REDIRECT

# Chemin du binaire PolarProxy (si non détecté automatiquement dans le PATH)
VITRAIL_POLARPROXY_BIN=
