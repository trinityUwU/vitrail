<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/software/polkit/policyconfig.dtd">
<policyconfig>
  <!--
    Placeholder de chemin d'installation : /usr/local/bin/vitrail-helper.
    À ajuster au packaging réel (EPIC 10, cf. PLAN.md §6ter) — doit correspondre exactement
    au chemin où `vitrail-helper` est installé sur le système cible.
  -->
  <vendor>Vitrail</vendor>
  <vendor_url>https://github.com/trinityUwU/vitrail</vendor_url>

  <action id="re.vitrail.helper.nft">
    <description>Appliquer ou retirer la chaîne nftables VITRAIL_REDIRECT</description>
    <message>L'authentification est requise pour modifier les règles réseau de Vitrail</message>
    <icon_name>security-high</icon_name>
    <defaults>
      <allow_any>auth_admin</allow_any>
      <allow_inactive>auth_admin</allow_inactive>
      <allow_active>auth_admin</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">/usr/local/bin/vitrail-helper</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">false</annotate>
  </action>
</policyconfig>
